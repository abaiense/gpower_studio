// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  ARTIST
  RECEPTIONIST
}

enum AppointmentStatus {
  PENDING        // agendado, aguardando depósito
  DEPOSIT_PAID   // depósito pago, confirmado
  CONFIRMED      // confirmado sem depósito (manual)
  IN_PROGRESS    // sessão em andamento
  COMPLETED      // sessão concluída
  CANCELLED      // cancelado pelo cliente
  NO_SHOW        // cliente não apareceu
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum ServiceCategory {
  TATTOO
  PIERCING
  CONSULTATION
  TOUCH_UP
  REMOVAL
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  PARTIALLY_PAID
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum ArtFileStatus {
  DRAFT
  SENT
  APPROVED
  REVISION_REQUESTED
}

enum FlashSlotStatus {
  OPEN
  CLAIMED
  EXPIRED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model Studio {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  logoUrl   String?
  timezone  String  @default("America/Sao_Paulo")
  currency  String  @default("BRL")
  isActive  Boolean @default(true)

  // Deposit config
  depositEnabled     Boolean @default(false)
  depositType        String  @default("PERCENTAGE") // "PERCENTAGE" | "FIXED"
  depositValue       Float   @default(30)            // 30% or R$30
  depositExpiryHours Int     @default(24)            // auto-cancel if unpaid after X hours

  // WhatsApp config (Meta WhatsApp Business API)
  whatsappEnabled       Boolean @default(false)
  whatsappPhoneNumberId String?
  whatsappAccessToken   String? // stored as-is for now (stub encryption)

  // Email config
  emailEnabled     Boolean @default(false)
  emailFromName    String?
  emailFromAddress String?

  // MercadoPago config
  mpAccessToken String? // access token do MP (nunca retornado em GET)
  mpPublicKey   String? // public key do MP

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  artists      Artist[]
  clients      Client[]
  services     Service[]
  appointments Appointment[]
  projects     Project[]
  consentForms ConsentForm[]
  artFiles     ArtFile[]
  flashSlots   FlashSlot[]

  @@map("studios")
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role    @default(ARTIST)
  isActive     Boolean @default(true)
  studioId     String
  artistId     String? @unique // se este user é um artista

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio        Studio         @relation(fields: [studioId], references: [id], onDelete: Cascade)
  artist        Artist?        @relation(fields: [artistId], references: [id])
  refreshTokens RefreshToken[]
  artFiles      ArtFile[]

  @@index([studioId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Artist {
  id              String  @id @default(cuid())
  firstName       String
  lastName        String
  bio             String?
  photoUrl        String?
  instagram       String?
  styles          String[] // ["blackwork", "realismo", "aquarela"]
  isActive        Boolean  @default(true)
  studioId        String
  commissionType  CommissionType @default(PERCENTAGE)
  commissionValue Float    @default(50) // % ou valor fixo

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio       Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user         User?
  appointments Appointment[]
  schedules    ArtistSchedule[]
  projects     Project[]
  flashSlots   FlashSlot[]

  @@index([studioId])
  @@map("artists")
}

model ArtistSchedule {
  id        String  @id @default(cuid())
  artistId  String
  dayOfWeek Int     // 0=domingo, 6=sábado
  startTime String  // "09:00"
  endTime   String  // "18:00"
  isActive  Boolean @default(true)

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([artistId, dayOfWeek])
  @@index([artistId])
  @@map("artist_schedules")
}

model Client {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String
  birthDate   DateTime?
  notes       String?
  allergies   String?
  isBlocked   Boolean   @default(false)
  blockReason String?
  studioId    String
  noShowCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio            Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  projects          Project[]
  consentForms      ConsentForm[]
  claimedFlashSlots FlashSlot[]

  @@index([studioId])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

model Service {
  id          String          @id @default(cuid())
  name        String
  description String?
  category    ServiceCategory
  durationMin Int             // duração em minutos
  basePrice   Float?          // null = preço por sessão
  isActive    Boolean         @default(true)
  studioId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  flashSlots   FlashSlot[]

  @@index([studioId])
  @@map("services")
}

model Project {
  id                String        @id @default(cuid())
  name              String
  description       String?
  estimatedSessions Int           @default(1)
  status            ProjectStatus @default(ACTIVE)
  depositAmount     Float?
  depositPaid       Boolean       @default(false)
  clientId          String
  artistId          String
  studioId          String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Restrict)
  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  artFiles     ArtFile[]
  consentForms ConsentForm[]

  @@index([clientId])
  @@index([artistId])
  @@index([studioId])
  @@map("projects")
}

model Appointment {
  id            String            @id @default(cuid())
  startAt       DateTime
  endAt         DateTime
  status        AppointmentStatus @default(PENDING)
  notes         String?
  totalPrice    Float?
  depositAmount Float?            @default(0)
  depositPaidAt DateTime?
  sessionNumber Int?              // ex: 3 (de 5 no projeto)
  clientId      String
  artistId      String
  serviceId     String
  studioId      String
  projectId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Restrict)
  service      Service       @relation(fields: [serviceId], references: [id])
  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id])
  payments     Payment[]
  consentForms ConsentForm[]
  flashSlot    FlashSlot?

  @@index([studioId])
  @@index([artistId])
  @@index([clientId])
  @@index([startAt])
  @@index([studioId, startAt]) // query mais comum: agenda do estúdio por data
  @@map("appointments")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  externalId       String?       // ID do pagamento no gateway (Stripe, MP)
  gateway          String?       // "stripe" | "mercadopago" | "pix"
  source           String?       // "infinitepay" | "mercadopago" | "manual"
  installments     Int?          // número de parcelas
  installmentValue Float?        // valor de cada parcela
  checkoutUrl      String?       // init_point MP (link de checkout)
  paidAt           DateTime?
  appointmentId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([externalId])
  @@map("payments")
}

model ConsentForm {
  id            String    @id @default(cuid())
  formType      String    // "TATTOO_ADULT" | "PIERCING_ADULT" | "MINOR" | "TOUCH_UP"
  data          Json      // respostas do formulário
  signatureUrl  String?   // imagem da assinatura (S3)
  signedAt      DateTime?
  signerIp      String?
  signerDevice  String?
  clientId      String
  appointmentId String?
  studioId      String
  consentToken          String?   @unique
  consentTokenExpiresAt DateTime?
  projectId             String?

  createdAt DateTime @default(now())

  client      Client       @relation(fields: [clientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  studio      Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id])

  @@index([clientId])
  @@index([appointmentId])
  @@index([studioId])
  @@map("consent_forms")
}

model ArtFile {
  id                     String        @id @default(cuid())
  version                Int
  filename               String
  s3Key                  String        @unique
  mimeType               String
  sizeBytes              Int           @default(0)
  status                 ArtFileStatus @default(DRAFT)
  notes                  String?
  clientNotes            String?
  approvalToken          String?       @unique
  approvalTokenExpiresAt DateTime?
  approvedAt             DateTime?
  approvedIp             String?
  projectId              String
  studioId               String
  uploadedBy             String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studio   Studio  @relation(fields: [studioId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@unique([projectId, version])
  @@index([projectId])
  @@index([studioId])
  @@index([approvalToken])
  @@map("art_files")
}

model FlashSlot {
  id                 String          @id @default(cuid())
  title              String
  description        String?
  originalPrice      Float
  discountPrice      Float
  sessionAt          DateTime
  claimDeadline      DateTime
  status             FlashSlotStatus @default(OPEN)
  claimToken         String          @unique
  artistId           String
  serviceId          String
  studioId           String
  claimedByClientId  String?
  claimedAt          DateTime?
  appointmentId      String?         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist          Artist       @relation(fields: [artistId], references: [id])
  service         Service      @relation(fields: [serviceId], references: [id])
  studio          Studio       @relation(fields: [studioId], references: [id], onDelete: Cascade)
  claimedByClient Client?      @relation(fields: [claimedByClientId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([studioId])
  @@index([claimToken])
  @@index([status])
  @@map("flash_slots")
}
